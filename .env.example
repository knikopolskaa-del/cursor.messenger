# Скопируйте в .env и при необходимости измените URL API.
VITE_API_URL=http://127.0.0.1:8000

# Backend secrets (dev values are ok; in prod use long random strings)
AUTH_PEPPER=change_me

# Yandex Object Storage (S3-compatible) — private bucket + presigned URLs
YOS_ENDPOINT=https://storage.yandexcloud.net
YOS_REGION=ru-central1
YOS_BUCKET=change_me
YOS_ACCESS_KEY_ID=change_me
YOS_SECRET_ACCESS_KEY=change_me
YOS_PRESIGN_TTL_SECONDS=900
YOS_PREFIX=messenger/
